---
import BaseLayout from '@/layouts/BaseLayout.astro';
import config from '@/data/site.config';

const legalPageTitle = 'Politique de confidentialité';
const legalPageDescription = `Politique de confidentialité de ${config.siteName} : données personnelles, cookies, analytics, affiliation et droits utilisateur.`;
const legalPageUrl = new URL(Astro.url.pathname, config.domain).toString();
---

<BaseLayout title="Confidentialité | Meilleur Magnésium Bisglycinate" description={legalPageDescription}>
  <script type="application/ld+json" slot="json-ld" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: config.domain },
      { '@type': 'ListItem', position: 2, name: legalPageTitle, item: legalPageUrl },
    ],
  })} />

  <script type="application/ld+json" slot="json-ld" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: legalPageTitle,
    headline: legalPageTitle,
    description: legalPageDescription,
    url: legalPageUrl,
    isPartOf: { '@type': 'WebSite', name: config.siteName, url: config.domain },
  })} />

  <main class="padding-section-medium" style="background-color: #ffffff;">
    <div class="container-large" style="max-width: 72rem; margin: 0 auto;">
      <h1 style="font-size: clamp(1.75rem, 1.2rem + 2.75vw, 2.5rem); color: #242424; margin-bottom: 2rem;">Politique de confidentialité</h1>

      <div style="color: #333; line-height: 1.8; font-size: 14px; max-width: 48rem;">
        <p>Cette politique explique comment les données personnelles peuvent être collectées, utilisées et protégées lorsque vous consultez le site <strong>{config.siteName}</strong>.</p>

        <h2 style="font-size: clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem); color: #242424; margin-top: 2rem; margin-bottom: 0.75rem;">1. Responsable du traitement</h2>
        <p><strong>SARL LMCORP</strong><br>Siège social : Quartier Industriel Sidi Ghanem, Lot N°208, Bureau N°DH7, Marrakech, Maroc<br>ICE : 003858984000079<br>IF : 71070947<br>Email : hello [at] le-meilleur-complement.fr</p>

        <h2 style="font-size: clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem); color: #242424; margin-top: 2rem; margin-bottom: 0.75rem;">2. Données collectées</h2>
        <p>Nous pouvons collecter des données de navigation, des données d’usage du site, des clics sur les liens d’affiliation et les informations que vous nous transmettez volontairement en cas de contact.</p>

        <h2 style="font-size: clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem); color: #242424; margin-top: 2rem; margin-bottom: 0.75rem;">3. Finalités</h2>
        <p>Ces données servent à assurer le bon fonctionnement du site, mesurer l’audience, améliorer les contenus, suivre les performances d’affiliation et répondre aux demandes de contact.</p>

        <h2 style="font-size: clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem); color: #242424; margin-top: 2rem; margin-bottom: 0.75rem;">4. Cookies</h2>
        <p>Le site peut utiliser des cookies techniques, des cookies de mesure d’audience et des cookies liés à l’affiliation. Vous pouvez configurer votre navigateur pour les refuser ou les supprimer.</p>

        <h2 style="font-size: clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem); color: #242424; margin-top: 2rem; margin-bottom: 0.75rem;">5. Partage des données</h2>
        <p>Les données ne sont pas vendues. Elles peuvent être transmises à des prestataires techniques, outils d’analyse ou partenaires d’affiliation lorsque cela est nécessaire au fonctionnement du site.</p>

        <h2 style="font-size: clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem); color: #242424; margin-top: 2rem; margin-bottom: 0.75rem;">6. Vos droits</h2>
        <p>Vous pouvez demander l’accès, la rectification, l’effacement ou l’opposition au traitement de vos données personnelles en écrivant à : <strong>hello [at] le-meilleur-complement.fr</strong></p>

        <h2 style="font-size: clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem); color: #242424; margin-top: 2rem; margin-bottom: 0.75rem;">7. Mise à jour</h2>
        <p>Cette politique peut être mise à jour à tout moment. La version publiée sur cette page est la version applicable.</p>
        <p><em>Dernière mise à jour : 28 avril 2026</em></p>
      </div>
    </div>
  </main>
</BaseLayout>
