---
interface NavLink {
  label: string;
  href: string;
}

interface Props {
  siteName: string;
  logoSrc: string;
  navLinks: NavLink[];
  ctaText: string;
  ctaLink: string;
}

const { siteName, logoSrc, navLinks, ctaText, ctaLink } = Astro.props;

const normalizePath = (value: string) => {
  if (!value || value.startsWith('#') || /^https?:\/\//i.test(value)) return value;
  const [pathOnly] = value.split('#');
  const normalized = pathOnly.endsWith('/') && pathOnly !== '/' ? pathOnly.slice(0, -1) : pathOnly;
  return normalized || '/';
};

const currentPath = normalizePath(Astro.url.pathname);
const isNavLinkActive = (href: string) => normalizePath(href) === currentPath;
const textKey = (value: string) => value.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();
const allLabels = navLinks.map((link) => `${link.label} ${link.href}`).join(' ');
const key = textKey(`${siteName} ${allLabels}`);

const getGuidesLabel = () => {
  if (/\b(comparativa|beneficios|opiniones|contraindicaciones|donde|sueno|manzanilla|preparar)\b/.test(key)) return 'Guías';
  if (/\b(comparativo|controindicazioni|italia)\b/.test(key)) return 'Guide';
  if (/\b(vergleich|erfahrungen|wirkung|nebenwirkungen|kaufen|rabattcode|schnell|rezeptfrei)\b/.test(key)) return 'Ratgeber';
  if (/\b(vergelijking|zonder|tijdens|poeder|tabletten|korting|ervaring)\b/.test(key)) return 'Gidsen';
  return 'Guides';
};

const getSectionLabel = () => {
  if (/\b(comparativa|beneficios|opiniones|contraindicaciones|donde|sueno|manzanilla|preparar)\b/.test(key)) return 'Articles utiles';
  if (/\b(comparativo|controindicazioni|italia)\b/.test(key)) return 'Risorse';
  if (/\b(vergleich|erfahrungen|wirkung|nebenwirkungen|kaufen|rabattcode|schnell|rezeptfrei)\b/.test(key)) return 'Weitere Seiten';
  if (/\b(vergelijking|zonder|tijdens|poeder|tabletten|korting|ervaring)\b/.test(key)) return 'Verder lezen';
  return 'Guides utiles';
};

const primaryLink = navLinks[0] ?? { label: 'Accueil', href: '/' };
const isReviewLike = (link: NavLink) => /avis|review|reviews|erfahrung|erfahrungen|opiniones|test|rabattcode|discount|code promo|korting/i.test(`${link.label} ${link.href}`);
const featuredLink = navLinks.slice(1).find(isReviewLike);
const dropdownLinks = navLinks.filter((link, index) => index !== 0 && link !== featuredLink);
const dropdownActive = dropdownLinks.some((link) => isNavLinkActive(link.href));
const featuredActive = featuredLink ? isNavLinkActive(featuredLink.href) : false;
const guidesLabel = getGuidesLabel();
const sectionLabel = getSectionLabel();
const ctaIsInternal = ctaLink.startsWith('#') || ctaLink.startsWith('/');
---

<header id="navbar" class="sticky top-0 z-[999] w-full border-b border-black/5 bg-grey-bg/95 py-3 backdrop-blur transition-shadow duration-300">
  <div class="mx-auto flex w-full max-w-[1440px] items-center justify-between gap-6 px-6 max-[767px]:px-5">
    <a href="/" class="flex shrink-0 items-center" aria-label={`Retour à l'accueil - ${siteName}`}>
      <img src={logoSrc} alt={siteName} class="h-10 w-auto max-[420px]:h-9" />
    </a>

    <div class="flex min-w-0 flex-1 items-center justify-end gap-5 max-[991px]:hidden">
      <nav class="flex min-w-0 items-center justify-end gap-1 rounded-full bg-white/45 px-2 py-1 shadow-[inset_0_0_0_1px_rgba(0,0,0,0.04)]" aria-label="Navigation principale">
        <a
          href={primaryLink.href}
          aria-current={isNavLinkActive(primaryLink.href) ? 'page' : undefined}
          class:list={[
            'max-w-[180px] truncate rounded-full px-4 py-2 font-primary text-sm font-semibold leading-none no-underline transition-colors duration-200 hover:bg-white hover:text-black',
            isNavLinkActive(primaryLink.href) ? 'bg-white text-orange shadow-sm' : 'text-[#595b61]',
          ]}
          title={primaryLink.label}
        >
          {primaryLink.label}
        </a>

        {dropdownLinks.length > 0 && (
          <div class="nav-dropdown relative">
            <button
              type="button"
              class:list={[
                'nav-dropdown-trigger inline-flex items-center gap-1.5 rounded-full px-4 py-2 font-primary text-sm font-semibold leading-none transition-colors duration-200 hover:bg-white hover:text-black',
                dropdownActive ? 'bg-white text-orange shadow-sm' : 'text-[#595b61]',
              ]}
              aria-expanded="false"
              aria-haspopup="true"
            >
              <span>{guidesLabel}</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="nav-dropdown-chevron transition-transform duration-200">
                <path d="m6 9 6 6 6-6" />
              </svg>
            </button>
            <div class="nav-dropdown-menu absolute left-1/2 top-[calc(100%+0.75rem)] w-[min(380px,calc(100vw-2rem))] -translate-x-1/2 rounded-3xl border border-black/10 bg-white p-2 shadow-[0_20px_60px_rgba(0,0,0,0.14)] transition-all duration-200">
              <div class="px-3 pb-2 pt-2 text-[11px] font-bold uppercase tracking-[0.16em] text-[#8a8a8a]">{sectionLabel}</div>
              {dropdownLinks.map((link) => (
                <a
                  href={link.href}
                  aria-current={isNavLinkActive(link.href) ? 'page' : undefined}
                  class:list={[
                    'block rounded-2xl px-3 py-2.5 font-primary text-sm font-semibold leading-snug no-underline transition-colors duration-200 hover:bg-grey-bg hover:text-black',
                    isNavLinkActive(link.href) ? 'bg-grey-bg text-orange' : 'text-[#595b61]',
                  ]}
                >
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        )}

        {featuredLink && (
          <a
            href={featuredLink.href}
            aria-current={featuredActive ? 'page' : undefined}
            class:list={[
              'max-w-[220px] truncate rounded-full px-4 py-2 font-primary text-sm font-semibold leading-none no-underline transition-colors duration-200 hover:bg-white hover:text-black',
              featuredActive ? 'bg-white text-orange shadow-sm' : 'text-[#595b61]',
            ]}
            title={featuredLink.label}
          >
            {featuredLink.label}
          </a>
        )}
      </nav>

      <a
        href={ctaLink}
        rel={ctaIsInternal ? undefined : 'nofollow sponsored'}
        target={ctaIsInternal ? undefined : '_blank'}
        class="inline-flex shrink-0 items-center gap-2 rounded-button bg-orange px-6 py-3 font-primary text-sm font-bold leading-none text-white no-underline transition-all duration-200 hover:-translate-y-px hover:bg-[#d66a12]"
      >
        <span>{ctaText}</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
          <path d="M5 12h14" />
          <path d="m12 5 7 7-7 7" />
        </svg>
      </a>
    </div>

    <button id="mobile-menu-btn" class="hidden flex-col items-center justify-center gap-1.5 rounded-full bg-white/70 p-3 max-[991px]:flex" aria-label="Ouvrir le menu" aria-expanded="false">
      <span class="hamburger-bar block h-[2px] w-6 origin-center bg-black transition-all duration-300"></span>
      <span class="hamburger-bar block h-[2px] w-6 bg-black transition-all duration-300"></span>
      <span class="hamburger-bar block h-[2px] w-6 origin-center bg-black transition-all duration-300"></span>
    </button>
  </div>
</header>

<div id="mobile-menu" class="mobile-overlay fixed inset-0 z-[9999] flex flex-col bg-grey-bg transition-all duration-300">
  <div class="flex items-center justify-between px-5 py-4">
    <img src={logoSrc} alt={siteName} class="h-9 w-auto" />
    <button id="mobile-menu-close" class="flex h-11 w-11 items-center justify-center rounded-full bg-white" aria-label="Fermer le menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6 6 18" />
        <path d="m6 6 12 12" />
      </svg>
    </button>
  </div>

  <nav class="flex flex-1 flex-col gap-7 overflow-y-auto px-6 pb-8 pt-4" aria-label="Navigation mobile">
    <a
      href={primaryLink.href}
      aria-current={isNavLinkActive(primaryLink.href) ? 'page' : undefined}
      class:list={[
        'rounded-2xl bg-white px-5 py-4 font-primary text-2xl font-bold leading-tight no-underline transition-colors duration-200 hover:text-orange',
        isNavLinkActive(primaryLink.href) ? 'text-orange' : 'text-black',
      ]}
    >
      {primaryLink.label}
    </a>

    {dropdownLinks.length > 0 && (
      <div>
        <p class="mb-3 px-1 text-xs font-bold uppercase tracking-[0.18em] text-[#8a8a8a]">{guidesLabel}</p>
        <div class="grid gap-2">
          {dropdownLinks.map((link) => (
            <a
              href={link.href}
              aria-current={isNavLinkActive(link.href) ? 'page' : undefined}
              class:list={[
                'rounded-2xl bg-white px-5 py-3.5 font-primary text-lg font-semibold leading-tight no-underline transition-colors duration-200 hover:text-orange',
                isNavLinkActive(link.href) ? 'text-orange' : 'text-black',
              ]}
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    )}

    {featuredLink && (
      <div>
        <p class="mb-3 px-1 text-xs font-bold uppercase tracking-[0.18em] text-[#8a8a8a]">Focus</p>
        <a
          href={featuredLink.href}
          aria-current={featuredActive ? 'page' : undefined}
          class:list={[
            'block rounded-2xl bg-white px-5 py-3.5 font-primary text-lg font-semibold leading-tight no-underline transition-colors duration-200 hover:text-orange',
            featuredActive ? 'text-orange' : 'text-black',
          ]}
        >
          {featuredLink.label}
        </a>
      </div>
    )}

    <a
      href={ctaLink}
      rel={ctaIsInternal ? undefined : 'nofollow sponsored'}
      target={ctaIsInternal ? undefined : '_blank'}
      class="mt-auto inline-flex items-center justify-center gap-2.5 rounded-button bg-orange px-8 py-4 font-primary text-lg font-bold leading-none text-white no-underline transition-all duration-200 hover:bg-[#d66a12]"
    >
      <span>{ctaText}</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
        <path d="M5 12h14" />
        <path d="m12 5 7 7-7 7" />
      </svg>
    </a>
  </nav>
</div>

<style>
  #navbar.scrolled {
    box-shadow: 0 1px 18px 0 rgba(0, 0, 0, 0.09);
  }

  .nav-dropdown-menu {
    visibility: hidden;
    opacity: 0;
    transform: translate(-50%, -0.25rem);
  }

  .nav-dropdown:hover .nav-dropdown-menu,
  .nav-dropdown:focus-within .nav-dropdown-menu,
  .nav-dropdown.open .nav-dropdown-menu {
    visibility: visible;
    opacity: 1;
    transform: translate(-50%, 0);
  }

  .nav-dropdown.open .nav-dropdown-chevron,
  .nav-dropdown:hover .nav-dropdown-chevron,
  .nav-dropdown:focus-within .nav-dropdown-chevron {
    transform: rotate(180deg);
  }

  .mobile-overlay {
    opacity: 0;
    pointer-events: none;
    transform: translateX(100%);
  }

  .mobile-overlay.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(0);
  }

  .hamburger-bar.active:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }

  .hamburger-bar.active:nth-child(2) {
    opacity: 0;
  }

  .hamburger-bar.active:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  if (navbar) {
    const onScroll = () => {
      navbar.classList.toggle('scrolled', window.scrollY > 10);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  const resetDropdown = (dropdown: HTMLElement) => {
    dropdown.classList.remove('open');
    dropdown.querySelector<HTMLButtonElement>('.nav-dropdown-trigger')?.setAttribute('aria-expanded', 'false');
    const menu = dropdown.querySelector<HTMLElement>('.nav-dropdown-menu');
    if (menu) {
      menu.style.visibility = '';
      menu.style.opacity = '';
      menu.style.transform = '';
    }
  };

  document.querySelectorAll<HTMLElement>('.nav-dropdown').forEach((dropdown) => {
    const trigger = dropdown.querySelector<HTMLButtonElement>('.nav-dropdown-trigger');
    const menu = dropdown.querySelector<HTMLElement>('.nav-dropdown-menu');
    const setMenuOpen = (open: boolean) => {
      dropdown.classList.toggle('open', open);
      trigger?.setAttribute('aria-expanded', String(open));
      if (menu) {
        menu.style.visibility = open ? 'visible' : '';
        menu.style.opacity = open ? '1' : '';
        menu.style.transform = open ? 'translate(-50%, 0)' : '';
      }
    };
    const toggle = () => {
      const next = !dropdown.classList.contains('open');
      document.querySelectorAll<HTMLElement>('.nav-dropdown.open').forEach(resetDropdown);
      setMenuOpen(next);
    };

    trigger?.addEventListener('click', (event) => {
      event.preventDefault();
      toggle();
    });

    dropdown.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => setMenuOpen(false)));
  });

  document.addEventListener('click', (event) => {
    const target = event.target as Node;
    document.querySelectorAll<HTMLElement>('.nav-dropdown.open').forEach((dropdown) => {
      if (!dropdown.contains(target)) resetDropdown(dropdown);
    });
  });

  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const closeBtn = document.getElementById('mobile-menu-close');
  const bars = btn?.querySelectorAll('.hamburger-bar');

  if (btn && menu && closeBtn && bars) {
    const openMenu = () => {
      menu.classList.add('open');
      bars.forEach((bar) => bar.classList.add('active'));
      document.body.style.overflow = 'hidden';
      btn.setAttribute('aria-expanded', 'true');
    };

    const closeMenu = () => {
      menu.classList.remove('open');
      bars.forEach((bar) => bar.classList.remove('active'));
      document.body.style.overflow = '';
      btn.setAttribute('aria-expanded', 'false');
    };

    btn.addEventListener('click', () => {
      menu.classList.contains('open') ? closeMenu() : openMenu();
    });

    closeBtn.addEventListener('click', closeMenu);
    menu.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeMenu();
        document.querySelectorAll<HTMLElement>('.nav-dropdown.open').forEach(resetDropdown);
      }
    });
  }
</script>
