---
import '@/styles/global.css';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import BrandPopup from '@/components/BrandPopup.astro';
import CookieNotice from '@/components/CookieNotice.astro';
import config from '@/data/site.config';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = config.seo.title,
  description = config.seo.description,
  ogImage = config.seo.ogImage,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, config.domain).toString();
const isAbsoluteUrl = (value: string) => /^https?:\/\//i.test(value);
const resolvedOgImage = isAbsoluteUrl(ogImage) ? ogImage : new URL(ogImage, config.domain).toString();
const analyticsMeasurementId = config.analyticsMeasurementId;
const robotsContent = config.isIndexable === false
  ? 'noindex, nofollow, noarchive, nosnippet, noimageindex'
  : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1';

// Auto-generate nav links from pages config (max 3 words each)
const navLinks = config.pages.map(p => ({ label: p.label, href: p.slug }));
const headerCtaLink = config.products[0].affiliateLink;
const footerLinks = [
  { label: 'Accueil', href: '/' },
  ...config.pages.map(p => ({ label: p.label, href: p.slug })),
];
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:type" content="article" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content={config.siteName} />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <meta name="twitter:image:alt" content={title} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=PT+Sans:ital,wght@0,400;0,700;1,400;1,700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>

    <!-- JSON-LD slot -->
    <slot name="json-ld" />

    {analyticsMeasurementId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${analyticsMeasurementId}`}></script>
        <script is:inline define:vars={{ analyticsMeasurementId }}>
          window.dataLayer = window.dataLayer || [];
          window.gtag = function gtag(){ window.dataLayer.push(arguments); };
          window.gtag('js', new Date());
          window.gtag('config', analyticsMeasurementId);
        </script>
        <script is:inline define:vars={{ analyticsMeasurementId }}>
          document.addEventListener('click', (event) => {
            const target = event.target;
            const link = target && target.closest ? target.closest('a[href]') : null;
            if (!link || typeof window.gtag !== 'function') return;

            let targetUrl;
            try {
              targetUrl = new URL(link.href, window.location.href);
            } catch {
              return;
            }

            if (targetUrl.hostname === window.location.hostname) return;

            const eventPayload = {
              send_to: analyticsMeasurementId,
              link_url: targetUrl.href,
              link_domain: targetUrl.hostname,
              link_text: (link.textContent || '').trim().slice(0, 120),
              page_location: window.location.href,
              transport_type: 'beacon',
              event_timeout: 350,
            };

            const isNewTab = (link.target || '').toLowerCase() === '_blank';
            const isModifiedClick = event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || event.button !== 0;

            if (isModifiedClick || isNewTab) {
              window.gtag('event', 'affiliate_click', eventPayload);
              return;
            }

            event.preventDefault();

            let navigated = false;
            const continueNavigation = () => {
              if (navigated) return;
              navigated = true;
              window.location.href = targetUrl.href;
            };

            window.gtag('event', 'affiliate_click', {
              ...eventPayload,
              event_callback: continueNavigation,
            });
            window.setTimeout(continueNavigation, 450);
          }, { capture: true });
        </script>
      </>
    )}
  </head>
  <body>
    <Navbar
      siteName={config.siteName}
      logoSrc="/logo.svg"
      navLinks={navLinks}
      ctaText="Acheter"
      ctaLink={headerCtaLink}
    />

    <slot />

    <BrandPopup
      brand={config.products[0].brand}
      productImage={config.products[0].image}
      productName={config.products[0].name}
      productType={config.products[0].productType}
      description={config.products[0].description}
      promoCode={config.products[0].promoCode}
      promoPercent={config.products[0].promoPercent}
      originalPrice={config.products[0].originalPrice}
      discountPrice={config.products[0].discountPrice}
      affiliateLink={config.products[0].affiliateLink}
      rating={config.products[0].rating}
    />

    <CookieNotice lang="fr" privacyHref="/privacy-policy/" />

    <Footer
      siteName={config.siteName}
      logoSrc="/logo.svg"
      navLinks={footerLinks}
      copyright="Tous droits réservés - Avis de Tim"
    />
  </body>
</html>
