---
interface Props {
  src: string;
  alt: string;
  caption?: string;
}

const { src, alt } = Astro.props;
---

<figure class="image-block">
  <img
    src={src}
    alt={alt}
    loading="lazy"
    class="image-block-img"
  />
</figure>

<style>
  .image-block {
    margin: 0 0 2rem;
  }

  .image-block-img {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 12px;
    display: block;
  }
  @media (min-width: 768px) {
    .image-block-img { border-radius: 16px; }
  }
</style>
