---
import config from '@/data/site.config';

interface Article {
  title?: string;
  label?: string;
  excerpt?: string;
  description?: string;
  image?: string;
  href?: string;
  slug?: string;
  date?: string;
  readTime?: string;
  type?: string;
}

interface Props {
  articles?: Article[];
  title?: string;
  readLabel?: string;
  currentPath?: string;
}

const localeByLang = {
  fr: { title: 'Dernières actualités', read: "Lire l’article", intro: 'Pour continuer votre lecture, consultez aussi', fallback: 'Guide pratique pour comparer les options et mieux choisir selon votre besoin.' },
  en: { title: 'Latest articles', read: 'Read article', intro: 'To continue reading, also see', fallback: 'A practical guide to compare the options and choose according to your needs.' },
  de: { title: 'Weitere Artikel', read: 'Artikel lesen', intro: 'Lesen Sie auch', fallback: 'Ein praktischer Guide, um die Optionen zu vergleichen und besser zu wählen.' },
  es: { title: 'Últimos artículos', read: 'Leer el artículo', intro: 'Para seguir leyendo, consulta también', fallback: 'Guía práctica para comparar las opciones y elegir mejor según tu necesidad.' },
  it: { title: 'Ultimi articoli', read: 'Leggi l’articolo', intro: 'Per continuare, leggi anche', fallback: 'Guida pratica per confrontare le opzioni e scegliere in base alle tue esigenze.' },
  nl: { title: 'Laatste artikelen', read: 'Artikel lezen', intro: 'Lees ook', fallback: 'Praktische gids om opties te vergelijken en beter te kiezen volgens je behoefte.' },
};

const detectLang = () => {
  const raw = [config.language, config.lang, config.locale, config.domain, config.siteName].filter(Boolean).join(' ').toLowerCase();
  if (raw.includes('.de') || raw.includes('de_') || raw.includes('de-')) return 'de';
  if (raw.includes('.es') || raw.includes('es_') || raw.includes('es-') || raw.includes('españ') || raw.includes('spanish')) return 'es';
  if (raw.includes('.it') || raw.includes('it_') || raw.includes('it-') || raw.includes('ital')) return 'it';
  if (raw.includes('.nl') || raw.includes('nl_') || raw.includes('nl-') || raw.includes('neder')) return 'nl';
  if (raw.includes('.com') && raw.includes('best')) return 'en';
  return 'fr';
};

const isContentPage = (item: Article) => {
  const href = item.href || item.slug || '';
  if (!href || href.startsWith('#') || !href.startsWith('/')) return false;
  return !/(mentions|politique|privacy|legal|impressum|datenschutz|cookies|404|thank)/i.test(href);
};

const normalizeHref = (item: Article) => item.href || item.slug || '/';
const current = Astro.props.currentPath || Astro.url.pathname;
const lang = detectLang();
const copy = localeByLang[lang] || localeByLang.fr;

const sourceArticles = (Astro.props.articles && Astro.props.articles.length > 0)
  ? Astro.props.articles
  : ((config.pages || []) as Article[])
      .filter(isContentPage)
      .filter((item) => normalizeHref(item) !== current)
      .map((item) => ({
        title: item.title || item.label || 'Guide',
        excerpt: item.excerpt || item.description || copy.fallback,
        image: item.image || config.seo?.ogImage || '/og-image.jpg',
        href: normalizeHref(item),
      }));

const articles = sourceArticles
  .filter((article) => normalizeHref(article) !== current)
  .slice(0, 3)
  .map((article) => ({
    title: article.title || article.label || 'Guide',
    excerpt: article.excerpt || article.description || copy.fallback,
    image: article.image || config.seo?.ogImage || '/og-image.jpg',
    href: normalizeHref(article),
  }));

const heading = Astro.props.title || copy.title;
const readLabel = Astro.props.readLabel || copy.read;
const textLinks = articles.slice(0, 3);
---

{articles.length > 0 && (
  <section class="articles-section" aria-labelledby="articles-heading">
    <div class="articles-container">
      <div class="articles-header">
        <h2 id="articles-heading" class="articles-heading">{heading}</h2>
        <div class="articles-line"></div>
      </div>

      {textLinks.length > 1 && (
        <p class="articles-intro">
          {copy.intro}{' '}
          {textLinks.map((article, index) => (
            <>
              <a href={article.href}>{article.title}</a>{index < textLinks.length - 2 ? ', ' : index === textLinks.length - 2 ? ' et ' : '.'}
            </>
          ))}
        </p>
      )}

      <div class="articles-grid">
        {articles.map((article) => (
          <a href={article.href} class="article-card">
            <div class="article-img-wrap">
              <img src={article.image} alt={article.title} class="article-img" loading="lazy" />
            </div>
            <div class="article-body">
              <h3 class="article-title">{article.title}</h3>
              <p class="article-excerpt">{article.excerpt}</p>
              <span class="article-read">
                {readLabel}
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .articles-section {
    background: #ffffff;
    padding-top: clamp(2.5rem, 4vw, 4rem);
    padding-bottom: clamp(3rem, 5vw, 5rem);
    width: 100%;
  }

  .articles-container {
    width: 100%;
    max-width: 92rem;
    margin: 0 auto;
    padding-left: clamp(1rem, 4vw, 4rem);
    padding-right: clamp(1rem, 4vw, 4rem);
  }

  .articles-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: clamp(1.75rem, 3vw, 3rem);
  }

  .articles-heading {
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: clamp(1.75rem, 2.6vw, 2.5rem);
    color: #242424;
    margin: 0;
    white-space: nowrap;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .articles-line {
    flex: 1;
    height: 1px;
    background: #dedbd4;
  }

  .articles-intro {
    max-width: 58rem;
    margin: -1.25rem 0 2rem;
    color: #6f6f6f;
    line-height: 1.6;
    font-size: clamp(1rem, 1vw, 1.125rem);
  }

  .articles-intro a {
    color: #ef7a1a;
    font-weight: 700;
    text-decoration: none;
    border-bottom: 1px solid rgba(239, 122, 26, 0.35);
  }

  .articles-intro a:hover {
    color: #d66a12;
    border-bottom-color: currentColor;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.25rem, 2.5vw, 2rem);
  }

  @media (min-width: 768px) {
    .articles-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (min-width: 1100px) {
    .articles-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }

  .article-card {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    background: #ffffff;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 18px 45px rgba(36, 36, 36, 0.09);
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .article-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 24px 60px rgba(36, 36, 36, 0.14);
  }

  .article-img-wrap {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #f4f2ec;
  }

  .article-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
  }

  .article-card:hover .article-img { transform: scale(1.04); }

  .article-body {
    padding: clamp(1.35rem, 2vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 1;
  }

  .article-title {
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: clamp(1.25rem, 1.65vw, 1.75rem);
    color: #242424;
    margin: 0;
    line-height: 1.18;
    letter-spacing: -0.02em;
    transition: color 0.2s ease;
  }

  .article-card:hover .article-title { color: #ef7a1a; }

  .article-excerpt {
    font-size: clamp(1rem, 1.15vw, 1.25rem);
    color: #767676;
    line-height: 1.55;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-read {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: clamp(1rem, 1vw, 1.125rem);
    color: #ef7a1a;
    margin-top: auto;
    padding-top: 0.5rem;
    transition: gap 0.2s ease, color 0.2s ease;
  }

  .article-card:hover .article-read { gap: 0.875rem; color: #d66a12; }

  @media (max-width: 767px) {
    .articles-header { align-items: flex-start; gap: 0.875rem; }
    .articles-heading { white-space: normal; }
    .articles-intro { margin-top: -0.75rem; }
    .article-body { padding: 1.25rem; }
  }
</style>
