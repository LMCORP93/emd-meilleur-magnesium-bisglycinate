---
/**
 * ContentImage - Image generated by Fal.ai, displayed inline in article content.
 * 
 * Usage:
 *   <ContentImage 
 *     src="/images/content/hero-banner.webp" 
 *     alt="Description SEO de l'image"
 *     caption="Légende conservée en source, non affichée"
 *   />
 */
interface Props {
  src: string;
  alt: string;
  caption?: string;
}

const { src, alt } = Astro.props;
---

<figure class="content-image">
  <img src={src} alt={alt} loading="lazy" decoding="async" />
</figure>

<style>
  .content-image {
    margin: 1.25rem 0;
    border-radius: 12px;
    overflow: hidden;
  }
  .content-image img {
    width: 100%;
    display: block;
    object-fit: cover;
    max-height: 340px;
  }
@media (max-width: 767px) {
    .content-image img {
      max-height: 240px;
    }
  }
</style>
