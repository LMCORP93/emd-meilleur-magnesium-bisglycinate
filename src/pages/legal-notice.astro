---
import BaseLayout from '@/layouts/BaseLayout.astro';
import config from '@/data/site.config';

const legalPageTitle = 'Mentions légales';
const legalPageDescription = `Informations légales et mentions obligatoires du site ${config.siteName}.`;
const legalPageUrl = new URL(Astro.url.pathname, config.domain).toString();
---

<BaseLayout title="Mentions légales | Meilleur Magnésium Bisglycinate" description={legalPageDescription}>
  <script type="application/ld+json" slot="json-ld" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: config.domain },
      { '@type': 'ListItem', position: 2, name: legalPageTitle, item: legalPageUrl },
    ],
  })} />

  <script type="application/ld+json" slot="json-ld" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: legalPageTitle,
    headline: legalPageTitle,
    description: legalPageDescription,
    url: legalPageUrl,
    isPartOf: { '@type': 'WebSite', name: config.siteName, url: config.domain },
  })} />

  <main class="padding-section-medium" style="background-color: #ffffff;">
    <div class="container-large" style="max-width: 72rem; margin: 0 auto;">
      <h1 style="font-size: clamp(1.75rem, 1.2rem + 2.75vw, 2.5rem); color: #242424; margin-bottom: 2rem;">Mentions légales</h1>

      <div style="color: #333; line-height: 1.8; font-size: 14px; max-width: 48rem;">
        <h2 style="font-size: clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem); color: #242424; margin-top: 2rem; margin-bottom: 0.75rem;">1. Éditeur du site</h2>
        <p>Le site <strong>{config.siteName}</strong> est édité par :</p>
        <p>
          <strong>SARL LMCORP</strong><br>
          Capital social : 10 000,00 MAD<br>
          ICE : 003858984000079<br>
          RC : 174701 - Registre du Commerce de Marrakech<br>
          IF : 71070947<br>
          Siège social : Quartier Industriel Sidi Ghanem, Lot N°208, Bureau N°DH7, Marrakech, Maroc<br>
          Email : hello@le-meilleur-complement.fr
        </p>
        <p><em>Directeur de la publication : Elias Abdallah, gérant unique.</em></p>

        <h2 style="font-size: clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem); color: #242424; margin-top: 2rem; margin-bottom: 0.75rem;">2. Hébergeur</h2>
        <p>Le site est hébergé par <strong>Cloudflare, Inc.</strong>, 101 Townsend Street, San Francisco, CA 94107, États-Unis.</p>

        <h2 style="font-size: clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem); color: #242424; margin-top: 2rem; margin-bottom: 0.75rem;">3. Propriété intellectuelle</h2>
        <p>Les textes, images, graphismes, logos et éléments éditoriaux présents sur le site sont protégés. Toute reproduction ou réutilisation sans autorisation écrite préalable est interdite.</p>

        <h2 style="font-size: clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem); color: #242424; margin-top: 2rem; margin-bottom: 0.75rem;">4. Affiliation</h2>
        <p>Le site contient des liens d’affiliation. Si vous cliquez sur certains liens et effectuez un achat, LMC peut percevoir une commission. Cela ne modifie pas le prix payé et n’achète pas notre avis éditorial.</p>

        <h2 style="font-size: clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem); color: #242424; margin-top: 2rem; margin-bottom: 0.75rem;">5. Information santé</h2>
        <p>Les contenus publiés sont fournis à titre informatif. Ils ne remplacent pas l’avis d’un professionnel de santé, notamment en cas de traitement, grossesse, maladie rénale ou symptôme persistant.</p>

        <h2 style="font-size: clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem); color: #242424; margin-top: 2rem; margin-bottom: 0.75rem;">6. Contact</h2>
        <p>Pour toute question, vous pouvez nous contacter à : <strong>hello@le-meilleur-complement.fr</strong></p>
      </div>
    </div>
  </main>
</BaseLayout>
